# ─── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/taskflow?schema=public

# ─── JWT secrets ──────────────────────────────────────────────────────────
# Generate strong random values for production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# ─── Agora (video/audio calls) ────────────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─── SMTP (outbound email) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TaskFlow <no-reply@example.com>

# ─── Branding ─────────────────────────────────────────────────────────────
APP_NAME=TaskFlow
APP_URL=https://app.example.com
APP_LOGO_URL=

# ─── Public URL of THIS backend (used in report email links) ─────────────
API_PUBLIC_URL=https://api.example.com
REPORT_FILE_TTL_DAYS=30

# ─── Daily report job ─────────────────────────────────────────────────────
DAILY_REPORT_CRON=30 20 * * *
DAILY_REPORT_TIMEZONE=Asia/Kolkata
DAILY_REPORT_ENABLED=true

# ─── Weekly report job ────────────────────────────────────────────────────
WEEKLY_REPORT_CRON=30 20 * * 6
WEEKLY_REPORT_TIMEZONE=Asia/Kolkata
WEEKLY_REPORT_ENABLED=true
